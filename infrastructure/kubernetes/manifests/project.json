{
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",

	"name": "manifests",
	"root": "infrastructure/kubernetes/manifests",
	"projectType": "application",

	"targets": {
		"render": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "{projectRoot}",
				"command": "make render"
			},
			"cache": true
		}
	}
}
